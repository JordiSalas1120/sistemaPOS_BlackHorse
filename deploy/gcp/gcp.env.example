# Variables de despliegue a GCP. Copiar a gcp.env y completar DB_PASS.
#   cp gcp.env.example gcp.env   &&   editar gcp.env
# gcp.env está en .gitignore (contiene el password de la BD).

export PROJECT=n8n-conexion-474818
export REGION=southamerica-east1

# Artifact Registry
export AR_REPO=talabarteria
export AR_HOST=southamerica-east1-docker.pkg.dev

# Cloud SQL
export SQL_INSTANCE=talabarteria-db
export SQL_CONN=n8n-conexion-474818:southamerica-east1:talabarteria-db
export DB_NAME=talabarteria_db
export DB_USER=talabarteria
export DB_PASS=CHANGEME_password_seguro

# Almacenamiento de imágenes (bucket global, debe ser único)
export BUCKET=n8n-conexion-474818-talabarteria-media

# Service Account de Cloud Run (compute por defecto): PROJECT_NUMBER-compute@...
export SA=640221760605-compute@developer.gserviceaccount.com

# Cloud Run
export BACKEND_SVC=talabarteria-backend
export FRONTEND_SVC=talabarteria-frontend
export IMG_BACKEND=southamerica-east1-docker.pkg.dev/n8n-conexion-474818/talabarteria/backend:latest
export IMG_FRONTEND=southamerica-east1-docker.pkg.dev/n8n-conexion-474818/talabarteria/frontend:latest

# Catálogo / WhatsApp (ajustar al número real del negocio)
export WHATSAPP_CATALOG_PHONE=591XXXXXXXXX
export CATALOG_CURRENCY_SYMBOL=Bs.
export CATALOG_SHOW_PRICES=true
